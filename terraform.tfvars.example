# =============================================================================
# Scenario 1 – BYO VNet with NAT Gateway egress (default / recommended)
# =============================================================================

location            = "swedencentral"
resource_group_name = "rg-aks-automatic"
cluster_name        = "aks-automatic"

enable_byo_vnet                 = true
vnet_name                       = "vnet-aks-automatic"
vnet_address_space              = "10.10.0.0/16"
node_subnet_name                = "snet-aks-nodes"
node_subnet_address_prefix      = "10.10.0.0/22"
apiserver_subnet_name           = "snet-aks-apiserver"
apiserver_subnet_address_prefix = "10.10.4.0/28"

egress_type              = "userAssignedNATGateway"
nat_gateway_idle_timeout = 4

pod_cidr       = "10.244.0.0/16"
service_cidr   = "10.245.0.0/16"
dns_service_ip = "10.245.0.10"

enable_private_cluster = false
authorized_ip_ranges   = []

# Ingress – link Azure DNS zones for automatic record management
# dns_zone_resource_ids = [
#   "/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.Network/dnsZones/example.com"
# ]

enable_service_mesh = false

upgrade_channel          = "stable"
node_os_upgrade_channel  = "NodeImage"
enable_prometheus        = true
image_cleaner_interval_hours = 48

tags = {
  environment = "production"
  managedBy   = "terraform"
}

# =============================================================================
# Scenario 2 – BYO VNet with UDR / forced-tunnelling through Azure Firewall
# Uncomment below and comment out Scenario 1 egress settings.
# =============================================================================

# egress_type         = "userDefinedRouting"
# firewall_private_ip = "10.10.8.4"

# =============================================================================
# Scenario 3 – BYO VNet with Load Balancer egress (dev/test)
# =============================================================================

# egress_type = "loadBalancer"

# =============================================================================
# Scenario 4 – Managed VNet (simplest, AKS manages everything)
# =============================================================================

# enable_byo_vnet = false
# (All vnet_*, node_subnet_*, apiserver_subnet_*, egress_* variables are ignored)

# =============================================================================
# Scenario 5 – Private cluster
# =============================================================================

# enable_private_cluster = true
# authorized_ip_ranges   = []       # IP ranges are ignored for private clusters
#
# For ALZ hub-spoke, point to a pre-created zone in the connectivity subscription:
# private_dns_zone_id = "/subscriptions/<conn-sub>/resourceGroups/<rg>/providers/Microsoft.Network/privateDnsZones/private.<region>.azmk8s.io"
#
# Use "system" (default) to let AKS create the zone in the node resource group.
# Use "none" to skip private DNS zone creation entirely.
