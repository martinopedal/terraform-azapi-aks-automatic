# =============================================================================
# Scenario 1 – ALZ Corp with vending (recommended)
#
# The platform pipeline (subscription vending + AVNM IPAM) pre-provisions:
#   - Spoke VNet, subnets (with delegations), NSG, UDR, hub peering
# This module consumes the subnet IDs and deploys:
#   - AKS Automatic, ACR, Key Vault, Private Endpoints, RBAC
# =============================================================================

location            = "swedencentral"
resource_group_name = "rg-aks-automatic"
cluster_name        = "aks-automatic-corp"

# BYO VNet is always true for Corp — the VNet is pre-provisioned by vending
enable_byo_vnet              = true
external_node_subnet_id      = "/subscriptions/<spoke-sub>/resourceGroups/<network-rg>/providers/Microsoft.Network/virtualNetworks/<vnet>/subnets/snet-aks-nodes"
external_apiserver_subnet_id = "/subscriptions/<spoke-sub>/resourceGroups/<network-rg>/providers/Microsoft.Network/virtualNetworks/<vnet>/subnets/snet-aks-apiserver"
external_pe_subnet_id        = "/subscriptions/<spoke-sub>/resourceGroups/<network-rg>/providers/Microsoft.Network/virtualNetworks/<vnet>/subnets/snet-private-endpoints"

# Egress through hub Azure Firewall (Corp default)
egress_type         = "userDefinedRouting"
firewall_private_ip = "10.0.1.4"

pod_cidr       = "10.244.0.0/16"   # Coordinate with ALZ IPAM — must not overlap routable space
service_cidr   = "10.245.0.0/16"
dns_service_ip = "10.245.0.10"

# Private cluster (Corp default — no public API server)
enable_private_cluster = true
# private_dns_zone_id = "/subscriptions/<conn-sub>/resourceGroups/<dns-rg>/providers/Microsoft.Network/privateDnsZones/private.<region>.azmk8s.io"

# ACR (Premium, private endpoint, no public access)
acr_name                = "acraksautocorp001"
acr_private_dns_zone_id = "/subscriptions/<conn-sub>/resourceGroups/<dns-rg>/providers/Microsoft.Network/privateDnsZones/privatelink.azurecr.io"

# Key Vault (RBAC, private endpoint, no public access)
keyvault_name          = "kv-aks-auto-corp-001"
kv_private_dns_zone_id = "/subscriptions/<conn-sub>/resourceGroups/<dns-rg>/providers/Microsoft.Network/privateDnsZones/privatelink.vaultcore.azure.net"

# Ingress DNS zones (from connectivity subscription)
# dns_zone_resource_ids = [
#   "/subscriptions/<conn-sub>/resourceGroups/<dns-rg>/providers/Microsoft.Network/privateDnsZones/app.contoso.corp"
# ]

tags = {
  environment = "production"
  managedBy   = "terraform"
}

# =============================================================================
# Scenario 2 – Standalone (module creates VNet, no vending)
# Uncomment below and remove the external_*_subnet_id lines above.
# =============================================================================

# enable_byo_vnet                 = true
# (do NOT set external_*_subnet_id — module creates subnets in network.tf)
# vnet_name                       = "vnet-aks-automatic"
# vnet_address_space              = "10.10.0.0/16"
# node_subnet_name                = "snet-aks-nodes"
# node_subnet_address_prefix      = "10.10.0.0/22"
# apiserver_subnet_name           = "snet-aks-apiserver"
# apiserver_subnet_address_prefix = "10.10.4.0/28"
# pe_subnet_name                  = "snet-private-endpoints"
# pe_subnet_address_prefix        = "10.10.12.0/24"
# egress_type                     = "userDefinedRouting"
# firewall_private_ip             = "10.10.8.4"
